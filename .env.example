# -----------------------------------------------------------------------------
# Pyth Casino example environment
# Active stack:
# - Native SOL deposit / withdrawal
# - Devnet Solana + devnet roulette program
# - Supabase Postgres for persistent balances
# -----------------------------------------------------------------------------

# Solana RPC / network
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# On-chain roulette
NEXT_PUBLIC_ROULETTE_PROGRAM_ID=9C2rBMBfZXDpPXtMdMiKs6cGjZjHujDEoVKmie6KRLJN
NEXT_PUBLIC_PYTH_BTC_FEED_ACCOUNT=
NEXT_PUBLIC_VAULT_PUBKEY=

# Native SOL treasury wallet
NEXT_PUBLIC_TREASURY_WALLET_ADDRESS=
TREASURY_PRIVATE_KEY=

# Persistent database (Supabase/Postgres)
# Hosted poolers usually need sslmode=require.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<host>:6543/postgres?sslmode=require

# Slots randomness provider
# local = current default provider
# pyth_entropy_v2 = reserved for future bridge-based Entropy integration
SLOTS_RANDOMNESS_PROVIDER=local
NEXT_PUBLIC_SLOTS_RANDOMNESS_PROVIDER=local
PYTH_ENTROPY_V2_CONTRACT_ADDRESS=
PYTH_ENTROPY_V2_CHAIN_ID=84532
PYTH_ENTROPY_V2_RPC_URL=https://sepolia.base.org
# Base Sepolia Entropy v2 (Official Pyth Entropy Contract)
PYTH_ENTROPY_V2_ENTROPY_ADDRESS=0x41c9e39574F40Ad34c79f1C99B66A45eFB830d4c
PYTH_ENTROPY_V2_DEFAULT_PROVIDER=0x6CC14824Ea2918f5De5C2f75A9Da968ad4BD6344
PYTH_ENTROPY_V2_CALLBACK_GAS_LIMIT=350000
PYTH_ENTROPY_V2_BRIDGE_PRIVATE_KEY=
PYTH_ENTROPY_V2_BRIDGE_SECRET=
PYTH_CASINO_APP_URL=http://localhost:3000

# App auth
JWT_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=

# Legacy token-tooling values
# Only needed if you still use the older helper scripts in /scripts.
NEXT_PUBLIC_TOKEN_MINT_ADDRESS=
NEXT_PUBLIC_TOKEN_AUTHORITY_ADDRESS=
